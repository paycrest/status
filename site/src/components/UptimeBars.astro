---
import type { SiteSummary } from "../lib/data";
import { dayKeys, dayStatus, monitoringStartDay } from "../lib/data";

interface Props {
  site: SiteSummary;
  days?: number;
}

const { site, days = 90 } = Astro.props;
const startDay = monitoringStartDay(site.slug);
const keys = dayKeys(days);
const cells = keys.map((d) => ({ day: d, state: dayStatus(site, d, startDay) }));
const firstLabel = new Date(keys[0]).toLocaleDateString(undefined, {
  month: "short",
  day: "numeric",
});
const lastLabel = "Today";
---

<div class="bars" role="img" aria-label={`${days}-day uptime for ${site.name}`}>
  {
    cells.map((c) => (
      <span
        class={`bar ${c.state}`}
        title={`${c.day} — ${c.state === "up" ? "Operational" : c.state === "down" ? "Outage" : "Not yet monitored"}`}
      />
    ))
  }
</div>
<div class="bars-meta">
  <span>{firstLabel}</span>
  <span>{site.uptimeMonth} uptime · past {days} days</span>
  <span>{lastLabel}</span>
</div>

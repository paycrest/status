---
import type { SiteSummary } from "../lib/data";
import {
  recentCandleSlots,
  candleStatusForSlot,
  monitoringStartMs,
  formatSlotLabel,
} from "../lib/data";

interface Props {
  site: SiteSummary;
  candles?: number;
}

// 96 candles × 15 min = 24h. Each candle reflects the latest known status
// at-or-before its 15-min slot end.
const { site, candles = 96 } = Astro.props;
const startMs = monitoringStartMs(site.slug);
const slots = recentCandleSlots(candles);
const cells = slots.map((slotMs) => ({
  slotMs,
  state: candleStatusForSlot(site.slug, slotMs, startMs),
}));
const firstLabel = formatSlotLabel(slots[0]);
const lastLabel = "Now";
---

<div
  class="bars"
  role="img"
  aria-label={`Last ${candles * 15} minutes uptime for ${site.name}`}
>
  {
    cells.map((c) => (
      <span
        class={`bar ${c.state}`}
        title={`${formatSlotLabel(c.slotMs)} — ${c.state === "up" ? "Operational" : c.state === "down" ? "Outage" : c.state === "degraded" ? "Degraded" : "No data"}`}
      />
    ))
  }
</div>
<div class="bars-meta">
  <span>{firstLabel}</span>
  <span>{site.uptimeDay} uptime · past 24 hours</span>
  <span>{lastLabel}</span>
</div>
